# Public build-time values. Safe to commit.
PUBLIC_SITE_NAME=Kimu Blog
PUBLIC_SITE_URL=https://www.zmkimu.com
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_ANALYTICS_ID=

# Private manage API runtime bindings. Non-secret values may live in wrangler.jsonc;
# secrets should stay in Cloudflare Secrets or local .dev.vars.
# If preview and production use different Cloudflare Access apps, override
# CF_ACCESS_AUD in wrangler.jsonc under env.preview.vars.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Secret. Do not commit a real value. Store in Cloudflare Secrets / local .dev.vars only.
GITHUB_APP_PRIVATE_KEY=

# Target repository metadata. These are safe to keep in wrangler.jsonc.
GITHUB_REPO_OWNER=ZM-Kimu
GITHUB_REPO_NAME=kimu-blog
GITHUB_REPO_BRANCH=main
GITHUB_COMMITTER_NAME=Kimu Bot
GITHUB_COMMITTER_EMAIL=bot@zmkimu.com
