{
	"name": "kimu-blog",
	"private": true,
	"version": "0.0.1",
	"description": "Content-first SvelteKit blog scaffold for Cloudflare Pages",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"preview:offline": "npm run build && wrangler pages dev .svelte-kit/cloudflare --ip 127.0.0.1 --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"ci": "npm run gen && npm run check && npm run lint && npm run build"
	},
	"dependencies": {
		"flubber": "^0.4.2",
		"gsap": "^3.14.2",
		"jose": "^6.2.2",
		"yaml": "^2.8.3",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/flubber": "^0.4.0",
		"@types/node": "^22",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"remark-gfm": "^4.0.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"wrangler": "^4.63.0"
	}
}
